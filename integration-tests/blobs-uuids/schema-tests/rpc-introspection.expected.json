{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_images",
      "description": "Get multiple `Image`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Images",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/ImageFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "projection",
          "description": "Response projection — controls which fields are returned",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "basic",
              "pk"
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Image"
          }
        }
      }
    },
    {
      "name": "get_image",
      "description": "Get a single `Image` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "projection",
          "description": "Response projection — controls which fields are returned",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "basic",
              "pk"
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/Image",
          "nullable": true
        }
      }
    },
    {
      "name": "delete_images",
      "description": "Delete multiple `Image`s given the provided `where` filter",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Images",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/ImageFilter"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/ImagePK"
          }
        }
      }
    },
    {
      "name": "delete_image",
      "description": "Delete a single `Image` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/ImagePK",
          "nullable": true
        }
      }
    },
    {
      "name": "update_images",
      "description": "Update multiple `Image`s matching the provided `where` filter with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Images",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/ImageFilter"
          }
        },
        {
          "name": "data",
          "description": "Data to update for matching Images",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/ImageUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/ImagePK"
          }
        }
      }
    },
    {
      "name": "update_image",
      "description": "Update a single `Image` by primary key with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "data",
          "description": "Data to update for Image",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/ImageUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/ImagePK",
          "nullable": true
        }
      }
    },
    {
      "name": "create_image",
      "description": "Create a new `Image` with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Image",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/ImageCreateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/ImagePK"
        }
      }
    },
    {
      "name": "create_images",
      "description": "Create multiple `Image`s with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Image",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageCreateInput"
            }
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/ImagePK"
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "Image": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "data": {
            "type": "string",
            "format": "byte"
          }
        },
        "required": [
          "id",
          "name",
          "data"
        ]
      },
      "UuidFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string",
            "format": "uuid"
          },
          "neq": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "StringFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "lt": {
            "type": "string"
          },
          "lte": {
            "type": "string"
          },
          "gt": {
            "type": "string"
          },
          "gte": {
            "type": "string"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          }
        }
      },
      "ImageFilter": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/UuidFilter"
          },
          "name": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "data": {
            "type": "string",
            "format": "byte"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/ImageFilter"
          }
        }
      },
      "ImageOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "name": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "data": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          }
        }
      },
      "ImagePK": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "id"
        ]
      },
      "ImageUpdateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "data": {
            "type": "string",
            "format": "byte"
          }
        }
      },
      "ImageCreateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "data": {
            "type": "string",
            "format": "byte"
          }
        },
        "required": [
          "name",
          "data"
        ]
      }
    }
  }
}