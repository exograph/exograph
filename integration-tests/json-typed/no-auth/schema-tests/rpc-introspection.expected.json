{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_todos",
      "description": "Get multiple `Todo`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Todos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/TodoFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TodoOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "projection",
          "description": "Response projection — controls which fields are returned",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "basic",
              "pk"
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/TodoPK"
              },
              {
                "$ref": "#/components/schemas/Todo"
              }
            ]
          }
        }
      }
    },
    {
      "name": "get_todo",
      "description": "Get a single `Todo` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "projection",
          "description": "Response projection — controls which fields are returned",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "basic",
              "pk"
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "nullable": true,
          "oneOf": [
            {
              "$ref": "#/components/schemas/TodoPK"
            },
            {
              "$ref": "#/components/schemas/Todo"
            }
          ]
        }
      }
    },
    {
      "name": "delete_todos",
      "description": "Delete multiple `Todo`s given the provided `where` filter",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Todos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/TodoFilter"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/TodoPK"
          }
        }
      }
    },
    {
      "name": "delete_todo",
      "description": "Delete a single `Todo` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/TodoPK",
          "nullable": true
        }
      }
    },
    {
      "name": "update_todos",
      "description": "Update multiple `Todo`s matching the provided `where` filter with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Todos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/TodoFilter"
          }
        },
        {
          "name": "data",
          "description": "Data to update for matching Todos",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/TodoUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/TodoPK"
          }
        }
      }
    },
    {
      "name": "update_todo",
      "description": "Update a single `Todo` by primary key with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "data",
          "description": "Data to update for Todo",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/TodoUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/TodoPK",
          "nullable": true
        }
      }
    },
    {
      "name": "create_todo",
      "description": "Create a new `Todo` with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Todo",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/TodoCreateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/TodoPK"
        }
      }
    },
    {
      "name": "create_todos",
      "description": "Create multiple `Todo`s with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Todo",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TodoCreateInput"
            }
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/TodoPK"
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "TodoPK": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ]
      },
      "Metadata": {
        "type": "object"
      },
      "Info": {
        "type": "object"
      },
      "Todo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "info": {
            "$ref": "#/components/schemas/Info"
          }
        },
        "required": [
          "id",
          "title",
          "metadata"
        ]
      },
      "IntFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "integer"
          },
          "neq": {
            "type": "integer"
          },
          "lt": {
            "type": "integer"
          },
          "lte": {
            "type": "integer"
          },
          "gt": {
            "type": "integer"
          },
          "gte": {
            "type": "integer"
          }
        }
      },
      "StringFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "lt": {
            "type": "string"
          },
          "lte": {
            "type": "string"
          },
          "gt": {
            "type": "string"
          },
          "gte": {
            "type": "string"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          }
        }
      },
      "TodoFilter": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "title": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TodoFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TodoFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/TodoFilter"
          }
        }
      },
      "TodoOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "title": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          }
        }
      },
      "TodoUpdateInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "info": {
            "$ref": "#/components/schemas/Info",
            "nullable": true
          }
        }
      },
      "TodoCreateInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "info": {
            "$ref": "#/components/schemas/Info",
            "nullable": true
          }
        },
        "required": [
          "title",
          "metadata"
        ]
      }
    }
  }
}