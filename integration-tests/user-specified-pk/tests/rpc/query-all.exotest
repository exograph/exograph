# Query all departments and products
stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_departments",
          "params": {
            "orderBy": [{"id": "ASC"}]
          }
        }
    response: |
      {
        "result": [
          {"id": "d1", "name": "D1"},
          {"id": "d2", "name": "D2"}
        ]
      }

  - operation:
      type: rpc
      payload: |
        {
          "method": "get_products",
          "params": {
            "orderBy": [{"id": "ASC"}]
          }
        }
    response: |
      {
        "result": [
          {"id": 1, "title": "D1P1", "department": {"id": "d1"}},
          {"id": 2, "title": "D1P2", "department": {"id": "d1"}},
          {"id": 3, "title": "D3P1", "department": {"id": "d2"}},
          {"id": 4, "title": "D2P2", "department": {"id": "d2"}}
        ]
      }
