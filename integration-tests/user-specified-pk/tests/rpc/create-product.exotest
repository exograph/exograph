# Test creating entity with user-specified PK via RPC
stages:
  # Create a product with user-specified PK
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_product",
          "params": {
            "data": {
              "id": 100,
              "title": "New Product",
              "department": {"id": "d1"}
            }
          }
        }
    response: |
      {
        "result": {"id": 100}
      }

  # Verify via get
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_product",
          "params": {
            "id": 100
          }
        }
    response: |
      {
        "result": {
          "id": 100,
          "title": "New Product",
          "department": {"id": "d1"}
        }
      }
