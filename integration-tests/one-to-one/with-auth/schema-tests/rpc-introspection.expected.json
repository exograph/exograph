{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_users",
      "description": "Get multiple `User`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Users",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/UserFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/User"
          }
        }
      }
    },
    {
      "name": "get_memberships",
      "description": "Get multiple `Membership`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Memberships",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/MembershipFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MembershipOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Membership"
          }
        }
      }
    },
    {
      "name": "get_user",
      "description": "Get a single `User` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/User",
          "nullable": true
        }
      }
    },
    {
      "name": "get_membership",
      "description": "Get a single `Membership` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/Membership",
          "nullable": true
        }
      }
    },
    {
      "name": "get_membership_by_user",
      "description": "Get a single `Membership` by user",
      "params": [
        {
          "name": "user",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/UserUniqueFilter"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/Membership",
          "nullable": true
        }
      }
    },
    {
      "name": "delete_users",
