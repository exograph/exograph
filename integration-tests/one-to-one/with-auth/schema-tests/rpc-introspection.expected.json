          },
          "kind": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "user": {
            "$ref": "#/components/schemas/UserFilter"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MembershipFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MembershipFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/MembershipFilter"
          }
        }
      },
      "UserFilter": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "name": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "membership": {
            "$ref": "#/components/schemas/MembershipFilter"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/UserFilter"
          }
        }
      },
      "MembershipOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "kind": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "user": {
            "$ref": "#/components/schemas/UserOrdering"
          }
