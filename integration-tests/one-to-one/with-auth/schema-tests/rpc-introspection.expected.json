{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_users",
      "description": "Get multiple `User`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Users",
          "required": false,
          "schema": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/UserFilter"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserOrdering"
            },
            "nullable": true
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer",
            "nullable": true
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer",
            "nullable": true
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/User"
          }
        }
      }
    },
    {
      "name": "get_memberships",
      "description": "Get multiple `Membership`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Memberships",
          "required": false,
          "schema": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/MembershipFilter"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MembershipOrdering"
            },
            "nullable": true
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer",
            "nullable": true
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer",
            "nullable": true
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Membership"
          }
        }
      }
    },
    {
      "name": "get_user",
      "description": "Get a single `User` given primary key fields",
      "params": [
        {
          "name": "by",
          "required": true,
          "schema": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "oneOf": [
            {
              "$ref": "#/components/schemas/User"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    {
      "name": "get_membership",
      "description": "Get a single `Membership`. Provide one of: (id), (user)",
      "params": [
        {
          "name": "by",
          "required": true,
          "schema": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer"
                  }
                },
                "required": [
                  "id"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "user": {
                    "$ref": "#/components/schemas/UserUniqueFilter"
                  }
                },
                "required": [
                  "user"
                ],
                "additionalProperties": false
              }
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "oneOf": [
            {
              "$ref": "#/components/schemas/Membership"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "IntFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "integer",
            "nullable": true
          },
          "neq": {
            "type": "integer",
            "nullable": true
          },
          "lt": {
            "type": "integer",
            "nullable": true
          },
          "lte": {
            "type": "integer",
            "nullable": true
          },
          "gt": {
            "type": "integer",
            "nullable": true
          },
          "gte": {
            "type": "integer",
            "nullable": true
          }
        }
      },
      "StringFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string",
            "nullable": true
          },
          "neq": {
            "type": "string",
            "nullable": true
          },
          "lt": {
            "type": "string",
            "nullable": true
          },
          "lte": {
            "type": "string",
            "nullable": true
          },
          "gt": {
            "type": "string",
            "nullable": true
          },
          "gte": {
            "type": "string",
            "nullable": true
          },
          "like": {
            "type": "string",
            "nullable": true
          },
          "ilike": {
            "type": "string",
            "nullable": true
          },
          "startsWith": {
            "type": "string",
            "nullable": true
          },
          "endsWith": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "MembershipFilter": {
        "type": "object",
        "properties": {
          "id": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/IntFilter"
              },
              {
                "type": "null"
              }
            ]
          },
          "kind": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/StringFilter"
              },
              {
                "type": "null"
              }
            ]
          },
          "user": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/UserFilter"
              },
              {
                "type": "null"
              }
            ]
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MembershipFilter"
            },
            "nullable": true
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MembershipFilter"
            },
            "nullable": true
          },
          "not": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/MembershipFilter"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "UserFilter": {
        "type": "object",
        "properties": {
          "id": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/IntFilter"
              },
              {
                "type": "null"
              }
            ]
          },
          "name": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/StringFilter"
              },
              {
                "type": "null"
              }
            ]
          },
          "membership": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/MembershipFilter"
              },
              {
                "type": "null"
              }
            ]
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserFilter"
            },
            "nullable": true
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserFilter"
            },
            "nullable": true
          },
          "not": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/UserFilter"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "MembershipOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ],
            "nullable": true
          },
          "kind": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ],
            "nullable": true
          },
          "user": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/UserOrdering"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "UserOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ],
            "nullable": true
          },
          "name": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ],
            "nullable": true
          },
          "membership": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/MembershipOrdering"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "UserRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ]
      },
      "Membership": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "kind": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserRef"
          }
        },
        "required": [
          "id",
          "kind",
          "user"
        ]
      },
      "UserUniqueFilter": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "nullable": true
          }
        }
      }
    }
  }
}