# Admin can update a membership and change the referenced user
operation:
  type: rpc
  payload: |
    {
      "method": "update_membership",
      "params": {
        "id": 1,
        "data": {
          "kind": "free",
          "user": {"id": 1}
        }
      }
    }
auth: |
  {
    "sub": 2,
    "role": "ADMIN"
  }
response: |
  {
    "result": {"id": 1}
  }
