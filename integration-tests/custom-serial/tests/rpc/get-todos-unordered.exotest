operation:
  type: rpc
  payload: |
    {
      "method": "get_todos"
    }
  unorderedPaths:
    - result
response: |
  {
    "result": [
      {
        "id": $.u2todoIds[1],
        "title": "U2-T2",
        "completed": false,
        "user": {
          "id": $.u2id
        }
      },
      {
        "id": $.u1todoIds[0],
        "title": "U1-T1",
        "completed": true,
        "user": {
          "id": $.u1id
        }
      },
      {
        "id": $.u2todoIds[0],
        "title": "U2-T1",
        "completed": true,
        "user": {
          "id": $.u2id
        }
      },
      {
        "id": $.u1todoIds[1],
        "title": "U1-T2",
        "completed": false,
        "user": {
          "id": $.u1id
        }
      }
    ]
  }
