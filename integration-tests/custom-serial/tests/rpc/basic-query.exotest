stages:
  # Query all users
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_users",
          "params": {}
        }
    response: |
      {
        "result": [
          {"id": $.u1id, "name": "U1"},
          {"id": $.u2id, "name": "U2"}
        ]
      }

  # Query all todos
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todos",
          "params": {
            "orderBy": [{"id": "ASC"}]
          }
        }
    response: |
      {
        "result": [
          {"id": $.u1todoIds[0], "title": "U1-T1", "completed": true, "user": {"id": $.u1id}},
          {"id": $.u1todoIds[1], "title": "U1-T2", "completed": false, "user": {"id": $.u1id}},
          {"id": $.u2todoIds[0], "title": "U2-T1", "completed": true, "user": {"id": $.u2id}},
          {"id": $.u2todoIds[1], "title": "U2-T2", "completed": false, "user": {"id": $.u2id}}
        ]
      }
