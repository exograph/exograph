{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_videos",
      "description": "Get multiple `Video`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Videos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/VideoFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "projection",
          "description": "Response projection — controls which fields are returned",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "basic",
              "pk"
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Video"
          }
        }
      }
    },
    {
      "name": "get_video",
      "description": "Get a single `Video` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "projection",
          "description": "Response projection — controls which fields are returned",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "basic",
              "pk"
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/Video",
          "nullable": true
        }
      }
    },
    {
      "name": "delete_videos",
      "description": "Delete multiple `Video`s given the provided `where` filter",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Videos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/VideoFilter"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/VideoPK"
          }
        }
      }
    },
    {
      "name": "delete_video",
      "description": "Delete a single `Video` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/VideoPK",
          "nullable": true
        }
      }
    },
    {
      "name": "update_videos",
      "description": "Update multiple `Video`s matching the provided `where` filter with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Videos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/VideoFilter"
          }
        },
        {
          "name": "data",
          "description": "Data to update for matching Videos",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/VideoUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/VideoPK"
          }
        }
      }
    },
    {
      "name": "update_video",
      "description": "Update a single `Video` by primary key with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "data",
          "description": "Data to update for Video",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/VideoUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/VideoPK",
          "nullable": true
        }
      }
    },
    {
      "name": "create_video",
      "description": "Create a new `Video` with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Video",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/VideoCreateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/VideoPK"
        }
      }
    },
    {
      "name": "create_videos",
      "description": "Create multiple `Video`s with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Video",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoCreateInput"
            }
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/VideoPK"
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "Video": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "maxLength": 30
          },
          "nonce": {
            "type": "integer"
          },
          "views": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9999999999
          },
          "filesize": {
            "type": "integer"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "nonce",
          "views",
          "filesize"
        ]
      },
      "IntFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "integer"
          },
          "neq": {
            "type": "integer"
          },
          "lt": {
            "type": "integer"
          },
          "lte": {
            "type": "integer"
          },
          "gt": {
            "type": "integer"
          },
          "gte": {
            "type": "integer"
          }
        }
      },
      "StringFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "lt": {
            "type": "string"
          },
          "lte": {
            "type": "string"
          },
          "gt": {
            "type": "string"
          },
          "gte": {
            "type": "string"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          }
        }
      },
      "VideoFilter": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "name": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "slug": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "nonce": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "views": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "filesize": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/VideoFilter"
          }
        }
      },
      "VideoOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "name": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "slug": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "nonce": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "views": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "filesize": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          }
        }
      },
      "VideoPK": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ]
      },
      "VideoUpdateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "maxLength": 30
          },
          "nonce": {
            "type": "integer"
          },
          "views": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9999999999
          },
          "filesize": {
            "type": "integer"
          }
        }
      },
      "VideoCreateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "maxLength": 30
          },
          "nonce": {
            "type": "integer"
          },
          "views": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9999999999
          },
          "filesize": {
            "type": "integer"
          }
        },
        "required": [
          "name",
          "slug",
          "nonce",
          "views",
          "filesize"
        ]
      }
    }
  }
}