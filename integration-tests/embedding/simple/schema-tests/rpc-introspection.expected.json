{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_documents",
      "description": "Get multiple `Document`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Documents",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/DocumentFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Document"
          }
        }
      }
    },
    {
      "name": "get_document",
      "description": "Get a single `Document` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/Document",
          "nullable": true
        }
      }
    },
    {
      "name": "delete_documents",
      "description": "Delete multiple `Document`s given the provided `where` filter",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Documents",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/DocumentFilter"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/DocumentPK"
          }
        }
      }
    },
    {
      "name": "delete_document",
      "description": "Delete a single `Document` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/DocumentPK",
          "nullable": true
        }
      }
    },
    {
      "name": "update_documents",
      "description": "Update multiple `Document`s matching the provided `where` filter with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Documents",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/DocumentFilter"
          }
        },
        {
          "name": "data",
          "description": "Data to update for matching Documents",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/DocumentUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/DocumentPK"
          }
        }
      }
    },
    {
      "name": "update_document",
      "description": "Update a single `Document` by primary key with the provided data. Any fields not provided will remain unchanged",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "data",
          "description": "Data to update for Document",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/DocumentUpdateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/DocumentPK",
          "nullable": true
        }
      }
    },
    {
      "name": "create_document",
      "description": "Create a new `Document` with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Document",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/DocumentCreateInput"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/DocumentPK"
        }
      }
    },
    {
      "name": "create_documents",
      "description": "Create multiple `Document`s with the provided data",
      "params": [
        {
          "name": "data",
          "description": "Data for creating Document",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentCreateInput"
            }
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/DocumentPK"
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "contentVector": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        },
        "required": [
          "id",
          "title",
          "content"
        ]
      },
      "IntFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "integer"
          },
          "neq": {
            "type": "integer"
          },
          "lt": {
            "type": "integer"
          },
          "lte": {
            "type": "integer"
          },
          "gt": {
            "type": "integer"
          },
          "gte": {
            "type": "integer"
          }
        }
      },
      "StringFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "lt": {
            "type": "string"
          },
          "lte": {
            "type": "string"
          },
          "gt": {
            "type": "string"
          },
          "gte": {
            "type": "string"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          }
        }
      },
      "VectorFilterArg": {
        "type": "object",
        "properties": {
          "distanceTo": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "distance": {
            "type": "number"
          }
        },
        "required": [
          "distanceTo"
        ],
        "description": "Vector similarity search argument"
      },
      "VectorFilter": {
        "type": "object",
        "properties": {
          "similar": {
            "$ref": "#/components/schemas/VectorFilterArg"
          },
          "eq": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "neq": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      },
      "DocumentFilter": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "title": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "content": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "contentVector": {
            "$ref": "#/components/schemas/VectorFilter"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/DocumentFilter"
          }
        }
      },
      "VectorOrdering": {
        "type": "object",
        "properties": {
          "distanceTo": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "direction": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          }
        },
        "description": "Vector similarity ordering"
      },
      "DocumentOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "title": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "content": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "contentVector": {
            "$ref": "#/components/schemas/VectorOrdering"
          }
        }
      },
      "DocumentPK": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "DocumentUpdateInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "contentVector": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "nullable": true
          }
        }
      },
      "DocumentCreateInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "contentVector": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "nullable": true
          }
        },
        "required": [
          "title",
          "content"
        ]
      }
    }
  }
}