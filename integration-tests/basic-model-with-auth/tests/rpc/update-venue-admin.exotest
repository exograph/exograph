# Test admin can update venue via RPC with projections
stages:
  # Admin updates venue — default projection (pk)
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_venue",
          "params": {
            "id": 1,
            "data": {"name": "Venue1-updated"}
          }
        }
    auth: |
      {
        "role": "ROLE_ADMIN"
      }
    response: |
      {
        "result": {"id": 1}
      }

  # Admin updates venue — basic projection returns all scalars
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_venue",
          "params": {
            "id": 1,
            "data": {"name": "Venue1-updated2"},
            "projection": "basic"
          }
        }
    auth: |
      {
        "role": "ROLE_ADMIN"
      }
    response: |
      {
        "result": {
          "id": 1,
          "name": "Venue1-updated2",
          "published": true,
          "latitude": 37.7749
        }
      }

  # Verify final state
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_venue",
          "params": {"id": 1}
        }
    auth: |
      {
        "role": "ROLE_ADMIN"
      }
    response: |
      {
        "result": {
          "id": 1,
          "name": "Venue1-updated2",
          "published": true,
          "latitude": 37.7749
        }
      }
