# User sees only published venues with nested concert predicates
stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_venues",
          "params": {
            "where": {"concerts": {"title": {"eq": "Concert1"}}}
          }
        }
    auth: |
      {
        "sub": 2,
        "role": "ROLE_USER"
      }
    response: |
      {
        "result": [
          {"id": 1, "name": "Venue1", "published": true, "latitude": 37.7749}
        ]
      }

  # Concert2 is at Venue2 (unpublished) - user can't see it
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_venues",
          "params": {
            "where": {"concerts": {"title": {"eq": "Concert2"}}}
          }
        }
    auth: |
      {
        "sub": 2,
        "role": "ROLE_USER"
      }
    response: |
      {
        "result": []
      }

  - operation:
      type: rpc
      payload: |
        {
          "method": "get_venues",
          "params": {
            "where": {"concerts": {"id": {"eq": 1}}}
          }
        }
    auth: |
      {
        "sub": 2,
        "role": "ROLE_USER"
      }
    response: |
      {
        "result": [
          {"id": 1, "name": "Venue1", "published": true, "latitude": 37.7749}
        ]
      }

  # Concert2 is at Venue2 (unpublished) - user can't see it
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_venues",
          "params": {
            "where": {"concerts": {"id": {"eq": 2}}}
          }
        }
    auth: |
      {
        "sub": 2,
        "role": "ROLE_USER"
      }
    response: |
      {
        "result": []
      }
