# Test non-admin gets auth error when trying collection update
stages:
  # Non-admin tries collection update - gets auth error
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_concerts",
          "params": {
            "where": {"title": {"eq": "Concert1"}},
            "data": {"title": "Concert1-hacked"}
          }
        }
    auth: |
      {
        "role": "ROLE_USER"
      }
    response: |
      {
        "error": {
          "code": -32004,
          "message": "Not authorized"
        }
      }

  # Verify all concerts are unchanged
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concerts",
          "params": {}
        }
    auth: |
      {
        "role": "ROLE_ADMIN"
      }
    response: |
      {
        "result": [
          {"id": 1, "title": "Concert1", "published": true, "price": "20.50", "venue": {"id": 1}},
          {"id": 2, "title": "Concert2", "published": false, "price": "12.50", "venue": {"id": 2}},
          {"id": 3, "title": "Concert3", "published": false, "price": "30.50", "venue": {"id": 1}},
          {"id": 4, "title": "Concert4", "published": true, "price": "22.50", "venue": {"id": 2}}
        ]
      }
