# Test admin can create venue via RPC with projections
stages:
  # Admin creates venue — default projection (pk)
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_venue",
          "params": {
            "data": {"name": "New Venue", "published": true, "latitude": 40.7128}
          }
        }
    auth: |
      {
        "role": "ROLE_ADMIN"
      }
    response: |
      {
        "result": {"id": 3}
      }

  # Admin creates venue — basic projection
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_venue",
          "params": {
            "data": {"name": "Another Venue", "published": false, "latitude": 51.5074},
            "projection": "basic"
          }
        }
    auth: |
      {
        "role": "ROLE_ADMIN"
      }
    response: |
      {
        "result": {
          "id": 4,
          "name": "Another Venue",
          "published": false,
          "latitude": 51.5074
        }
      }

  # Verify both created
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_venues",
          "params": {
            "where": {"id": {"gte": 3}},
            "orderBy": [{"id": "ASC"}]
          }
        }
    auth: |
      {
        "role": "ROLE_ADMIN"
      }
    response: |
      {
        "result": [
          {
            "id": 3,
            "name": "New Venue",
            "published": true,
            "latitude": 40.7128
          },
          {
            "id": 4,
            "name": "Another Venue",
            "published": false,
            "latitude": 51.5074
          }
        ]
      }
