# User can filter by their own email
operation:
  type: rpc
  payload: |
    {
      "method": "get_people",
      "params": {
        "where": {"email": {"eq": "p1@example.com"}}
      }
    }
auth: |
  {
    "sub": $.p1id
  }
response: |
  {
    "result": [
      {"id": $.p1id, "name": "P1", "age": 10, "authId": 1}
    ]
  }
