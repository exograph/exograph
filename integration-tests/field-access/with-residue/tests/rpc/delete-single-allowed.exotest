# self.authId == AuthContext.id, so delete is allowed
stages:
  # Delete with basic projection — returns id, name, age, authId of deleted row
  - operation:
      type: rpc
      payload: |
        {
          "method": "delete_person",
          "params": {
            "id": $.p1id,
            "projection": "basic"
          }
        }
    auth: |
      {
        "sub": $.p1id
      }
    response: |
      {
        "result": {
          "id": $.p1id,
          "name": "P1",
          "age": 10,
          "authId": $.p1id
        }
      }

  # Verify deletion
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_person",
          "params": {"id": $.p1id}
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": null
      }
