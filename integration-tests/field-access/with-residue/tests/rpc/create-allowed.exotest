# self.authId == AuthContext.id, so email field is allowed
stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_person",
          "params": {
            "data": {"name": "P5", "age": 50, "email": "p5@example.com", "authId": 5}
          }
        }
    auth: |
      {
        "sub": 5
      }
    response: |
      {
        "result": {"id": 5}
      }
