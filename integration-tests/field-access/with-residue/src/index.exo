context AuthContext {
  @jwt("sub") id: Int
  @jwt role: String
}

@postgres
module PeopleDatabase {
  @projection(
    // Redefine basic to exclude access-controlled field
    basic = id + name + age + authId,
    full = /basic + email
  )
  @access(true)
  @plural("People")
  type Person {
    @pk id: Int = autoIncrement()
    name: String
    age: Int
    authId: Int

    @access(self.authId == AuthContext.id || AuthContext.role == "admin")
    email: String?
  }
}
