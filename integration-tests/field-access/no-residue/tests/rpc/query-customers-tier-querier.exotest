# A tier-querier can see all fields including the restricted internalTier field.
# internalTier has @access(query=AuthContext.role == "tier-querier" || AuthContext.role == "admin").
# Entity access: self.userId == AuthContext.id || AuthContext.role == "admin".
# Since neither condition is met for all rows, the tier-querier only sees their own customer.
operation:
  type: rpc
  payload: |
    {
      "method": "get_customers"
    }
auth: |
  {
    "sub": 1,
    "role": "tier-querier"
  }
response: |
  {
    "result": [
      {
        "id": $.c1id,
        "name": "C1",
        "userId": 1,
        "internalTier": 1
      }
    ]
  }
