# A regular user cannot see the internalTier field (access requires tier-querier or admin role).
# internalTier has @access(query=AuthContext.role == "tier-querier" || AuthContext.role == "admin").
# This resolves to false for a regular user, so internalTier is omitted from the response.
# Entity access: self.userId == AuthContext.id -> user sees only their own customer.
operation:
  type: rpc
  payload: |
    {
      "method": "get_customers"
    }
auth: |
  {
    "sub": 1,
    "role": "user"
  }
response: |
  {
    "result": [
      {
        "id": $.c1id,
        "name": "C1",
        "userId": 1
      }
    ]
  }
