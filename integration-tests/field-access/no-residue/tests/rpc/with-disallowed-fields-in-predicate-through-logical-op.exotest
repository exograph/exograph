operation:
  type: rpc
  payload: |
    {
      "method": "get_customers",
      "params": {
        "where": {"and": [{"internalTier": {"eq": 1}}, {"internalTier": {"lte": 1}}]}
      }
    }
auth: |
  {
    "sub": 1
  }
response: |
  {
    "error": {
      "code": -32004,
      "message": "Not authorized"
    }
  }
