stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_customer",
          "params": {
            "id": 1,
            "data": {"name": "C5", "internalTier": 55}
          }
        }
    auth: |
      {
        "sub": 1,
        "role": "tier-updater"
      }
    response: |
      {
        "result": {"id": 1}
      }

  # tier-updater can update internalTier but NOT query it — full projection errors
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_customer",
          "params": {"id": 1, "projection": "full"}
        }
    auth: |
      {
        "sub": 1,
        "role": "tier-updater"
      }
    response: |
      {
        "error": {
          "code": -32004,
          "message": "Not authorized"
        }
      }

  # tier-querier CAN query internalTier — full projection succeeds
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_customer",
          "params": {"id": 1, "projection": "full"}
        }
    auth: |
      {
        "sub": 1,
        "role": "tier-querier"
      }
    response: |
      {
        "result": {
          "id": 1,
          "name": "C5",
          "userId": 1,
          "internalTier": 55
        }
      }
