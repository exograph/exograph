context AuthContext {
  @jwt("sub") id: Int
  @jwt role: String
}

@postgres
module ConcertModule {
  @projection(
    // Override basic to exclude the access-controlled venue field
    basic = [id, title, published],
    withVenue = [/basic, venue/basic]
  )
  @access(true)
  type Concert {
    @pk id: Int = autoIncrement()
    title: String
    @access(AuthContext.role == "admin")
    @column("venueid") venue: Venue
    published: Boolean
  }

  @access(true)
  type Venue {
    @pk id: Int = autoIncrement()
    name: String
    concerts: Set<Concert>?
  }
}
