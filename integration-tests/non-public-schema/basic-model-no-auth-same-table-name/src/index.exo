// Same table name ("info"), but in different schemas ("concerts" and "venues")

@postgres
module ConcertModule {
  @table(name="info", schema="concerts")
  @projection(
    withVenue = [/basic, venue/basic],
    withVenueDetails = [/basic, venue/nameOnly, venue/locationOnly],
    summary = [id, title]
  )
  @access(true)
  type Concert {
    @pk
    id: Int = autoIncrement();
    title: String
    @column("venueid") venue: Venue
    published: Boolean
    @precision(20) @scale(2) price: Decimal
  }

  @table(name="info", schema="venues")
  @projection(
    nameOnly = [id, name],
    locationOnly = [id, latitude],
    empty = []
  )
  @access(true)
  type Venue {
    @pk id: Int = autoIncrement() 
    name: String
    concerts: Set<Concert>? 
    published: Boolean
    @singlePrecision latitude: Float
  }
}
