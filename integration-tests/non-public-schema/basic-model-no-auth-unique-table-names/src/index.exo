@postgres
module ConcertModule {
  @table(name="concerts", schema="c")
  @projection(
    withVenue = /basic + venue/basic,
    withVenueDetails = /basic + venue/nameOnly + venue/locationOnly,
    summary = id + title
  )
  @access(true)
  type Concert {
    @pk
    id: Int = autoIncrement();
    title: String
    @column("venueid") venue: Venue
    published: Boolean
    @precision(20) @scale(2) price: Decimal
  }

  @table(name="venues", schema="v")
  @projection(
    nameOnly = id + name,
    locationOnly = id + latitude
  )
  @access(true)
  type Venue {
    @pk id: Int = autoIncrement() 
    name: String
    concerts: Set<Concert>? 
    published: Boolean
    @singlePrecision latitude: Float
  }
}
