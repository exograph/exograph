stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "delete_concerts",
          "params": {
            "where": {"title": {"eq": "Concert1"}}
          }
        }
    response: |
      {
        "result": [{"id": 1}]
      }

  # Verify it was deleted
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concert",
          "params": {"id": 1}
        }
    response: |
      {
        "result": null
      }
