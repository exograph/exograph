# Test single create concert via RPC - with venue ref, returns PK only
stages:
  # Create a new concert referencing venue 1
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_concert",
          "params": {
            "data": {
              "title": "New Concert",
              "venue": {"id": 1},
              "published": true,
              "price": "15.00"
            }
          }
        }
    response: |
      {
        "result": {"id": 5}
      }

  # Verify it was created (default basic projection)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concert",
          "params": {
            "id": 5
          }
        }
    response: |
      {
        "result": {
          "id": 5,
          "title": "New Concert",
          "published": true,
          "price": "15.00",
          "venue": {"id": 1}
        }
      }

  # Verify with withVenue projection — venue expanded
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concert",
          "params": {
            "id": 5,
            "projection": "withVenue"
          }
        }
    response: |
      {
        "result": {
          "id": 5,
          "title": "New Concert",
          "published": true,
          "price": "15.00",
          "venue": {
            "id": 1,
            "name": "Venue1",
            "published": true,
            "latitude": 37.7749
          }
        }
      }

  # Verify with summary projection — only id and title
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concert",
          "params": {
            "id": 5,
            "projection": "summary"
          }
        }
    response: |
      {
        "result": {
          "id": 5,
          "title": "New Concert"
        }
      }

  # Verify with withVenueDetails — union of venue/nameOnly + venue/locationOnly
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concert",
          "params": {
            "id": 5,
            "projection": "withVenueDetails"
          }
        }
    response: |
      {
        "result": {
          "id": 5,
          "title": "New Concert",
          "published": true,
          "price": "15.00",
          "venue": {
            "id": 1,
            "name": "Venue1",
            "latitude": 37.7749
          }
        }
      }
