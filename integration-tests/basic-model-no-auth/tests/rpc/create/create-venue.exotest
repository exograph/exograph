stages:
  # Create a new venue
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_venue",
          "params": {
            "data": {
              "name": "V1",
              "published": true,
              "latitude": 1.0
            }
          }
        }
    response: |
      {
        "result": {"id": 3}
      }

  # Verify it was created
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_venue",
          "params": {
            "id": 3
          }
        }
    response: |
      {
        "result": {
          "id": 3,
          "name": "V1",
          "published": true,
          "latitude": 1.0
        }
      }
