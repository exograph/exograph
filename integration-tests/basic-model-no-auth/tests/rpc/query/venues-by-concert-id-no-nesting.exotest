# Essentially, all venues, but with a nested where clause
operation:
  type: rpc
  payload: |
    {
      "method": "get_venues",
      "params": {
        "where": {"concerts": {"id": {"lt": 100}}}
      }
    }
  unorderedPaths:
    - result
response: |
  {
    "result": [
      {
        "id": 1,
        "name": "Venue1",
        "published": true,
        "latitude": 37.7749
      },
      {
        "id": 2,
        "name": "Venue2",
        "published": false,
        "latitude": 35.6762
      }
    ]
  }
