# Test collection update with nested predicate and projection
stages:
  # Collection update with summary projection
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_concerts",
          "params": {
            "where": {"venue": {"name": {"eq": "Venue1"}}},
            "data": {"price": "50"},
            "projection": "summary"
          }
        }
      unorderedPaths:
        - result
    response: |
      {
        "result": [
          {"id": 1, "title": "Concert1"},
          {"id": 3, "title": "Concert3"}
        ]
      }

  # Verify the updates still applied
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concert",
          "params": {"id": 1}
        }
    response: |
      {
        "result": {
          "id": 1,
          "title": "Concert1",
          "published": true,
          "price": "50.00",
          "venue": {"id": 1}
        }
      }

  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concert",
          "params": {"id": 3}
        }
    response: |
      {
        "result": {
          "id": 3,
          "title": "Concert3",
          "published": true,
          "price": "50.00",
          "venue": {"id": 1}
        }
      }
