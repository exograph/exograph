# Test multi update with where filter via RPC - returns list of PKs
stages:
  # Update all concerts at venue 1 to set published=false
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_concerts",
          "params": {
            "where": {
              "venue": {
                "name": {
                  "eq": "Venue1"
                }
              }
            },
            "data": {
              "published": false
            }
          }
        }
      unorderedPaths:
        - result
    response: |
      {
        "result": [
          {
            "id": 1
          },
          {
            "id": 3
          }
        ]
      }

  # Verify the updates - all concerts should now have published=false
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concerts",
          "params": {}
        }
      unorderedPaths:
        - result
    response: |
      {
        "result": [
          {
            "id": 1,
            "title": "Concert1",
            "published": false,
            "price": "20.50",
            "venue": {
              "id": 1
            }
          },
          {
            "id": 2,
            "title": "Concert2",
            "published": false,
            "price": "12.50",
            "venue": {
              "id": 2
            }
          },
          {
            "id": 3,
            "title": "Concert3",
            "published": false,
            "price": "30.50",
            "venue": {
              "id": 1
            }
          },
          {
            "id": 4,
            "title": "Concert4",
            "published": false,
            "price": "22.50",
            "venue": {
              "id": 2
            }
          }
        ]
      }
