# Test multi delete with where filter via RPC - returns list of PKs
stages:
  # Delete concerts at venue 1 (Concert1 and Concert3)
  - operation:
      type: rpc
      payload: |
        {
          "method": "delete_concerts",
          "params": {
            "where": {"venue": {"name": {"eq": "Venue1"}}}
          }
        }
      unorderedPaths:
        - result
    response: |
      {
        "result": [{"id": 1}, {"id": 3}]
      }

  # Verify remaining concerts are only venue 2 concerts
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_concerts",
          "params": {}
        }
      unorderedPaths:
        - result
    response: |
      {
        "result": [
          {"id": 2, "title": "Concert2", "published": false, "price": "12.50", "venue": {"id": 2}},
          {"id": 4, "title": "Concert4", "published": false, "price": "22.50", "venue": {"id": 2}}
        ]
      }
