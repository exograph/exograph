stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_issue",
          "params": {
            "data": {"title": "I-new", "assignee": {"id": $.u1id}}
          }
        }
    auth: |
      {
        "sub": $.u1id
      }
    response: |
      {
        "result": {"id": ($.issue2Id + 1)}
      }
