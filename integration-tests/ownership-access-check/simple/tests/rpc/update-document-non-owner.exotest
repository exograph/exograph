# Non-owner cannot update another user's document
stages:
  # User 3 tries to update document 1 (owned by user 2) - should return null
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_document",
          "params": {
            "id": 1,
            "data": {"content": "hacked-content"}
          }
        }
    auth: |
      {
        "sub": 3,
        "role": "USER"
      }
    response: |
      {
        "result": null
      }

  # Verify document is unchanged
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {"id": 1}
        }
    auth: |
      {
        "sub": 2,
        "role": "ADMIN"
      }
    response: |
      {
        "result": {"id": 1, "content": "content1", "user": {"id": 2}}
      }
