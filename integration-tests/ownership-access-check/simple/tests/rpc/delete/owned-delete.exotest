# User cannot delete a document that is not theirs
stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "delete_document",
          "params": {"id": 1}
        }
    auth: |
      {
        "sub": 3,
        "role": "USER"
      }
    invariants:
      - path: ../system-state.gql
    response: |
      {
        "result": null
      }
