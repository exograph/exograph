# Test get_document by PK enforces ownership access control.
# Document has @access(AuthContext.role == "ADMIN" || AuthContext.id == self.user.id).
# Since User has @access(true), the user reference is always visible.
stages:
  # Admin can get any document
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "by": {"id": 1}
          }
        }
    auth: |
      {
        "sub": 2,
        "role": "ADMIN"
      }
    response: |
      {
        "result": {
          "id": 1,
          "content": "content1",
          "user": {
            "id": 2
          }
        }
      }

  # Owner can get their own document
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "by": {"id": 1}
          }
        }
    auth: |
      {
        "sub": 2,
        "role": "USER"
      }
    response: |
      {
        "result": {
          "id": 1,
          "content": "content1",
          "user": {
            "id": 2
          }
        }
      }

  # Non-owner cannot get another user's document (returns null)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "by": {"id": 1}
          }
        }
    auth: |
      {
        "sub": 1,
        "role": "USER"
      }
    response: |
      {
        "result": null
      }
