# Bulk update only affects documents owned by the user
stages:
  # User 2 bulk-updates all documents - should only affect their own (doc 1 and 2)
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_documents",
          "params": {
            "data": {"content": "bulk-updated"}
          }
        }
    auth: |
      {
        "sub": 2,
        "role": "USER"
      }
    response: |
      {
        "result": [{"id": 1}, {"id": 2}]
      }

  # Verify user 2's document was updated
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {"id": 1}
        }
    auth: |
      {
        "role": "ADMIN"
      }
    response: |
      {
        "result": {"id": 1, "content": "bulk-updated", "user": {"id": 2}}
      }

  # Verify user 1's document was NOT updated
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {"id": 3}
        }
    auth: |
      {
        "role": "ADMIN"
      }
    response: |
      {
        "result": {"id": 3, "content": "content3", "user": {"id": 1}}
      }

  # Verify user 3's document was NOT updated
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {"id": 4}
        }
    auth: |
      {
        "role": "ADMIN"
      }
    response: |
      {
        "result": {"id": 4, "content": "content4", "user": {"id": 3}}
      }
