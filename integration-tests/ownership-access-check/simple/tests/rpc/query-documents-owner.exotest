# User can only query their own documents via RPC.
# User 2 owns documents 1 and 2.
# Since User has @access(true), the user reference is always visible.
operation:
  type: rpc
  payload: |
    {
      "method": "get_documents"
    }
  unorderedPaths:
    - result
auth: |
  {
    "sub": 2,
    "role": "USER"
  }
response: |
  {
    "result": [
      {
        "id": 1,
        "content": "content1",
        "user": {
          "id": 2
        }
      },
      {
        "id": 2,
        "content": "content2",
        "user": {
          "id": 2
        }
      }
    ]
  }
