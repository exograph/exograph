# Test delete with projections
stages:
  # Delete questions first (foreign key constraint)
  - operation:
      type: rpc
      payload: |
        {
          "method": "delete_questions",
          "params": {
            "where": {"project": {"id": {"eq": $.p2Id}}}
          }
        }
    auth: |
      {
        "isAdmin": true
      }
    response: |
      {
        "result": [
          {"id": $.q2Ids[0]},
          {"id": $.q2Ids[1]}
        ]
      }

  # Admin deletes project — withOwner projection returns expanded owner
  - operation:
      type: rpc
      payload: |
        {
          "method": "delete_project",
          "params": {
            "id": $.p2Id,
            "projection": "withOwner"
          }
        }
    auth: |
      {
        "isAdmin": true
      }
    response: |
      {
        "result": {
          "id": $.p2Id,
          "name": "P2",
          "owner": {
            "id": $.u2Id,
            "name": "U2"
          }
        }
      }

  # Verify it's gone
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_project",
          "params": {
            "id": $.p2Id
          }
        }
    auth: |
      {
        "isAdmin": true
      }
    response: |
      {
        "result": null
      }
