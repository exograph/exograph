{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_chess_pieces",
      "description": "Get multiple `ChessPiece`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for ChessPieces",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/ChessPieceFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChessPieceOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/ChessPiece"
          }
        }
      }
    },
    {
      "name": "get_chess_piece",
      "description": "Get a single `ChessPiece` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/ChessPiece",
          "nullable": true
        }
      }
    },
    {
      "name": "delete_chess_pieces",
      "description": "Delete multiple `ChessPiece`s given the provided `where` filter",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for ChessPieces",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/ChessPieceFilter"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/ChessPiecePK"
          }
        }
      }
    },
    {
      "name": "delete_chess_piece",
      "description": "Delete a single `ChessPiece` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/ChessPiecePK",
          "nullable": true
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "ChessPiece": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "position_history": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "neighbor_info": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "id",
          "name",
          "position_history",
          "neighbor_info"
        ]
      },
      "IntFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "integer"
          },
          "neq": {
            "type": "integer"
          },
          "lt": {
            "type": "integer"
          },
          "lte": {
            "type": "integer"
          },
          "gt": {
            "type": "integer"
          },
          "gte": {
            "type": "integer"
          }
        }
      },
      "StringFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "lt": {
            "type": "string"
          },
          "lte": {
            "type": "string"
          },
          "gt": {
            "type": "string"
          },
          "gte": {
            "type": "string"
          },
          "like": {
            "type": "string"
          },
          "ilike": {
            "type": "string"
          },
          "startsWith": {
            "type": "string"
          },
          "endsWith": {
            "type": "string"
          }
        }
      },
      "ChessPieceFilter": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "name": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "position_history": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "neighbor_info": {
            "$ref": "#/components/schemas/StringFilter"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChessPieceFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChessPieceFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/ChessPieceFilter"
          }
        }
      },
      "ChessPieceOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "name": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          }
        }
      },
      "ChessPiecePK": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      }
    }
  }
}
