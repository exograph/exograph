      "name": "get_books",
      "description": "Get multiple `Book`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Books",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/BookFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BookOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "projection",
          "description": "Response projection — controls which fields are returned",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "basic",
              "pk"
            ]
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/BookPK"
              },
              {
                "$ref": "#/components/schemas/Book"
              }
            ]
          }
        }
      }
    },
