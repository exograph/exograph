# Test creating a user with nested RSVPs via RPC (same data as GraphQL normal-insert)
stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_user",
          "params": {
            "data": {
              "username": "Bob04",
              "primaryEmailId": "bob",
              "emailDomain": "example.com",
              "rsvps": [{"event": "Concert2"}]
            }
          }
        }
    response: |
      {
        "result": {"id": 2}
      }

  # Verify user was created
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user_by_username",
          "params": {"username": "Bob04"}
        }
    response: |
      {
        "result": {"id": 2, "username": "Bob04", "primaryEmailId": "bob", "secondaryEmailId": null, "emailDomain": "example.com"}
      }
