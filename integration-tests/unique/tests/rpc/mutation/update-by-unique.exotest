# Test update by unique constraint fields via RPC
stages:
  # Update non-existent user by username - returns null
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_user_by_username",
          "params": {
            "username": "NonExistentUser",
            "data": {"primaryEmailId": "new-email"}
          }
        }
    response: |
      {
        "result": null
      }

  # Update non-existent rsvp by composite unique - returns null
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_rsvp_by_event_rsvp",
          "params": {
            "event": "NonExistentEvent", "user": {"id": $.alice_user_id},
            "data": {"count": 99}
          }
        }
    response: |
      {
        "result": null
      }

  # Update rsvp by composite unique constraint (event + user)
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_rsvp_by_event_rsvp",
          "params": {
            "event": "Concert1", "user": {"id": $.alice_user_id},
            "data": {"count": 5}
          }
        }
    response: |
      {
        "result": {"id": $.alice_rsvp_id[0]}
      }

  # Verify rsvp update
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_rsvp",
          "params": {
            "id": $.alice_rsvp_id[0]
          }
        }
    response: |
      {
        "result": {"id": $.alice_rsvp_id[0], "event": "Concert1", "count": 5, "user": {"id": $.alice_user_id}}
      }

  # Update internal rsvp by composite unique constraint (event + user)
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_internal_rsvp_by_event_rsvp",
          "params": {
            "event": "InternalConcert1", "user": {"id": $.alice_user_id},
            "data": {"count": 10}
          }
        }
    response: |
      {
        "result": {"id": $.alice_internal_rsvp_id[0]}
      }

  # Verify internal rsvp update
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_internal_rsvp",
          "params": {
            "id": $.alice_internal_rsvp_id[0]
          }
        }
    response: |
      {
        "result": {"id": $.alice_internal_rsvp_id[0], "event": "InternalConcert1", "count": 10, "user": {"id": $.alice_user_id}}
      }

  # Update user by unique constraint (username)
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_user_by_username",
          "params": {
            "username": "Alice02",
            "data": {"primaryEmailId": "alice-updated"}
          }
        }
    response: |
      {
        "result": {"id": $.alice_user_id}
      }

  # Verify user update
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user_by_username",
          "params": {
            "username": "Alice02"
          }
        }
    response: |
      {
        "result": {"id": $.alice_user_id, "username": "Alice02", "primaryEmailId": "alice-updated", "secondaryEmailId": "alice2", "emailDomain": "example.com"}
      }
