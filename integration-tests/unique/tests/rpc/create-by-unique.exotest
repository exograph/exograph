# Test creating an entity with unique constraints via RPC
stages:
  # Create a new user
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_user",
          "params": {
            "data": {
              "username": "newuser",
              "primaryEmailId": "new@example.com",
              "emailDomain": "example.com"
            }
          }
        }
    response: |
      {
        "result": {"id": 2}
      }

  # Verify via get by unique
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user_by_username",
          "params": {
            "username": "newuser"
          }
        }
    response: |
      {
        "result": {
          "id": 2,
          "username": "newuser",
          "primaryEmailId": "new@example.com",
          "secondaryEmailId": null,
          "emailDomain": "example.com"
        }
      }
