# Test get_<entity> with invalid param combinations via RPC
stages:
  # Unknown parameter
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user",
          "params": {
            "nonExistent": "value"
          }
        }
    response: |
      {
        "error": {
          "code": -32602,
          "message": "Missing required parameter: id"
        }
      }

  # Unknown parameter with extraneous param present
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user",
          "params": {
            "id": 1,
            "nonExistent": "value"
          }
        }
    response: |
      {
        "error": {
          "code": -32602,
          "message": "Unknown parameter: nonExistent"
        }
      }

  # Params that don't match PK params (primaryEmailId is not a valid param for get_user)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user",
          "params": {
            "primaryEmailId": "alice"
          }
        }
    response: |
      {
        "error": {
          "code": -32602,
          "message": "Missing required parameter: id"
        }
      }

  # No params at all (missing id)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user",
          "params": {}
        }
    response: |
      {
        "error": {
          "code": -32602,
          "message": "Missing required parameter: id"
        }
      }
