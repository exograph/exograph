# Test get_<entity> with unique constraint fields via RPC
stages:
  # Test get_user by single-field unique constraint (username)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user_by_username",
          "params": {
            "username": "Alice02"
          }
        }
    response: |
      {
        "result": {"id": $.alice_user_id, "username": "Alice02", "primaryEmailId": "alice", "secondaryEmailId": "alice2", "emailDomain": "example.com"}
      }

  # Test get_user by composite unique constraint (primary_email)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user_by_primary_email",
          "params": {
            "primaryEmailId": "alice", "emailDomain": "example.com"
          }
        }
    response: |
      {
        "result": {"id": $.alice_user_id, "username": "Alice02", "primaryEmailId": "alice", "secondaryEmailId": "alice2", "emailDomain": "example.com"}
      }

  # Test get_user by composite unique constraint (secondary_email)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user_by_secondary_email",
          "params": {
            "secondaryEmailId": "alice2", "emailDomain": "example.com"
          }
        }
    response: |
      {
        "result": {"id": $.alice_user_id, "username": "Alice02", "primaryEmailId": "alice", "secondaryEmailId": "alice2", "emailDomain": "example.com"}
      }

  # Test get_user by unique constraint with non-existent value - returns null
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user_by_username",
          "params": {
            "username": "nonexistent"
          }
        }
    response: |
      {
        "result": null
      }

  # Test get_user by PK (regression)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user",
          "params": {
            "id": 1
          }
        }
    response: |
      {
        "result": {"id": $.alice_user_id, "username": "Alice02", "primaryEmailId": "alice", "secondaryEmailId": "alice2", "emailDomain": "example.com"}
      }

  # Test get_user by non-existent PK - returns null
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_user",
          "params": {
            "id": 99999
          }
        }
    response: |
      {
        "result": null
      }

  # Test get_rsvp by PK (regression)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_rsvp",
          "params": {
            "id": 1
          }
        }
    response: |
      {
        "result": {
          "id": $.alice_rsvp_id[0],
          "event": "Concert1",
          "user": {
            "id": $.alice_user_id
          },
          "count": 1
        }
      }
