{
  "openrpc": "1.3.2",
  "info": {
    "title": "Exograph RPC API",
    "version": "1.0.0"
  },
  "methods": [
    {
      "name": "get_foos",
      "description": "Get multiple `Foo`s given the provided `where` filter, order by, limit, and offset",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Foos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/FooFilter"
          }
        },
        {
          "name": "orderBy",
          "description": "Ordering for the results",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FooOrdering"
            }
          }
        },
        {
          "name": "limit",
          "description": "Maximum number of results to return",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "offset",
          "description": "Number of results to skip",
          "required": false,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Foo"
          }
        }
      }
    },
    {
      "name": "get_foo",
      "description": "Get a single `Foo` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/Foo",
          "nullable": true
        }
      }
    },
    {
      "name": "delete_foos",
      "description": "Delete multiple `Foo`s given the provided `where` filter",
      "params": [
        {
          "name": "where",
          "description": "Filter conditions for Foos",
          "required": false,
          "schema": {
            "$ref": "#/components/schemas/FooFilter"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/FooPK"
          }
        }
      }
    },
    {
      "name": "delete_foo",
      "description": "Delete a single `Foo` by primary key",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "$ref": "#/components/schemas/FooPK",
          "nullable": true
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "Foo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "verylong": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "verylong"
        ]
      },
      "IntFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "integer"
          },
          "neq": {
            "type": "integer"
          },
          "lt": {
            "type": "integer"
          },
          "lte": {
            "type": "integer"
          },
          "gt": {
            "type": "integer"
          },
          "gte": {
            "type": "integer"
          }
        }
      },
      "DecimalFilter": {
        "type": "object",
        "properties": {
          "eq": {
            "type": "string"
          },
          "neq": {
            "type": "string"
          },
          "lt": {
            "type": "string"
          },
          "lte": {
            "type": "string"
          },
          "gt": {
            "type": "string"
          },
          "gte": {
            "type": "string"
          }
        }
      },
      "FooFilter": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IntFilter"
          },
          "verylong": {
            "$ref": "#/components/schemas/DecimalFilter"
          },
          "and": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FooFilter"
            }
          },
          "or": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FooFilter"
            }
          },
          "not": {
            "$ref": "#/components/schemas/FooFilter"
          }
        }
      },
      "FooOrdering": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          },
          "verylong": {
            "type": "string",
            "enum": [
              "ASC",
              "DESC"
            ]
          }
        }
      },
      "FooPK": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      }
    }
  }
}
