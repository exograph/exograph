envs:
  "ENV1": "ENV1-value"
stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_env",
          "params": {
            "key": "ENV1"
          }
        }
    response: |
      {
        "result": "ENV1-value"
      }

  - operation:
      type: rpc
      payload: |
        {
          "method": "get_env",
          "params": {
            "key": "NON_EXISTENT"
          }
        }
    response: |
      {
        "result": null
      }
