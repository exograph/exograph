# Admin can query all permissions via RPC with both document and user references.
operation:
  type: rpc
  payload: |
    {
      "method": "get_permissions"
    }
  unorderedPaths:
    - result
auth: |
  {
    "role": "admin"
  }
response: |
  {
    "result": [
      {
        "id": $.d1PermissionIds[0],
        "read": true,
        "write": true,
        "document": {
          "id": $.d1Id
        },
        "user": {
          "id": $.u1Id
        }
      },
      {
        "id": $.d1PermissionIds[1],
        "read": false,
        "write": false,
        "document": {
          "id": $.d1Id
        },
        "user": {
          "id": $.u2Id
        }
      },
      {
        "id": $.d1PermissionIds[2],
        "read": true,
        "write": false,
        "document": {
          "id": $.d1Id
        },
        "user": {
          "id": $.u3Id
        }
      },
      {
        "id": $.d2PermissionIds[0],
        "read": false,
        "write": false,
        "document": {
          "id": $.d2Id
        },
        "user": {
          "id": $.u1Id
        }
      },
      {
        "id": $.d2PermissionIds[1],
        "read": true,
        "write": true,
        "document": {
          "id": $.d2Id
        },
        "user": {
          "id": $.u2Id
        }
      },
      {
        "id": $.d2PermissionIds[2],
        "read": true,
        "write": false,
        "document": {
          "id": $.d2Id
        },
        "user": {
          "id": $.u3Id
        }
      },
      {
        "id": $.d3PermissionIds[0],
        "read": true,
        "write": false,
        "document": {
          "id": $.d3Id
        },
        "user": {
          "id": $.u4Id
        }
      }
    ]
  }
