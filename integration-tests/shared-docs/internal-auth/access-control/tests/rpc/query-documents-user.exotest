# User3 can only query documents where they have read=true permission.
# Document access: admin || self.permissions.some(p => p.user.id == AuthContext.id && p.read)
# u3 has read=true on d1 and d2, no permission on d3 -> d1 and d2 visible.
operation:
  type: rpc
  payload: |
    {
      "method": "get_documents"
    }
  unorderedPaths:
    - result
auth: |
  {
    "sub": $.u3Id,
    "role": "user"
  }
response: |
  {
    "result": [
      {
        "id": $.d1Id,
        "content": "d1"
      },
      {
        "id": $.d2Id,
        "content": "d2"
      }
    ]
  }
