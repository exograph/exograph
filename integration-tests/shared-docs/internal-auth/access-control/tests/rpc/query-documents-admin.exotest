# Admin can query all documents via RPC.
# Document has no ManyToOne relations, so only scalar fields are returned.
operation:
  type: rpc
  payload: |
    {
      "method": "get_documents"
    }
  unorderedPaths:
    - result
auth: |
  {
    "role": "admin"
  }
response: |
  {
    "result": [
      {
        "id": $.d1Id,
        "content": "d1"
      },
      {
        "id": $.d2Id,
        "content": "d2"
      },
      {
        "id": $.d3Id,
        "content": "d3"
      }
    ]
  }
