# Test get_permission by PK enforces access control.
# Permission has @access(query = AuthContext.role == "admin" || (self.user.id == AuthContext.id && self.read)).
# Document has @access(query = AuthContext.role == "admin" || self.permissions.some(p => p.user.id == AuthContext.id && p.read)).
# User has @access(AuthContext.role == "admin" || self.id == AuthContext.id).
stages:
  # Admin can get any permission with both refs visible
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_permission",
          "params": {
            "by": {"id": $.d1PermissionIds[0]}
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "id": $.d1PermissionIds[0],
          "read": true,
          "write": true,
          "document": {
            "id": $.d1Id
          },
          "user": {
            "id": $.u1Id
          }
        }
      }

  # User1 can get their own readable permission
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_permission",
          "params": {
            "by": {"id": $.d1PermissionIds[0]}
          }
        }
    auth: |
      {
        "sub": $.u1Id,
        "role": "user"
      }
    response: |
      {
        "result": {
          "id": $.d1PermissionIds[0],
          "read": true,
          "write": true,
          "document": {
            "id": $.d1Id
          },
          "user": {
            "id": $.u1Id
          }
        }
      }

  # User2 cannot get user1's permission (returns null)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_permission",
          "params": {
            "by": {"id": $.d1PermissionIds[0]}
          }
        }
    auth: |
      {
        "sub": $.u2Id,
        "role": "user"
      }
    response: |
      {
        "result": null
      }

  # User1 cannot get their own non-readable permission (read=false blocks access)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_permission",
          "params": {
            "by": {"id": $.d2PermissionIds[0]}
          }
        }
    auth: |
      {
        "sub": $.u1Id,
        "role": "user"
      }
    response: |
      {
        "result": null
      }
