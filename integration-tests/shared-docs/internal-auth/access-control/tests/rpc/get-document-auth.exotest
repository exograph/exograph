# Test get_document by PK enforces access control.
# Document access: admin || self.permissions.some(p => p.user.id == AuthContext.id && p.read)
stages:
  # Admin can get any document
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "id": $.d1Id
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "id": $.d1Id,
          "content": "d1"
        }
      }

  # User1 can get d1 (has read=true permission)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "id": $.d1Id
          }
        }
    auth: |
      {
        "sub": $.u1Id,
        "role": "user"
      }
    response: |
      {
        "result": {
          "id": $.d1Id,
          "content": "d1"
        }
      }

  # User1 cannot get d2 (has read=false permission)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "id": $.d2Id
          }
        }
    auth: |
      {
        "sub": $.u1Id,
        "role": "user"
      }
    response: |
      {
        "result": null
      }

  # User4 cannot get d1 (no permission at all)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "id": $.d1Id
          }
        }
    auth: |
      {
        "sub": $.u4Id,
        "role": "user"
      }
    response: |
      {
        "result": null
      }

  # User4 can get d3 (has read=true permission)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_document",
          "params": {
            "id": $.d3Id
          }
        }
    auth: |
      {
        "sub": $.u4Id,
        "role": "user"
      }
    response: |
      {
        "result": {
          "id": $.d3Id,
          "content": "d3"
        }
      }
