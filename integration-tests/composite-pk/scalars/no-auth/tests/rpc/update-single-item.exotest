# Test update with composite primary key 
stages:
  # Update person with composite PK - returns composite PK fields
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_person",
          "params": {
            "firstName": "John",
            "lastName": "DoeAlbany",
            "data": {
              "age": 21
            }
          }
        }
    response: |
      {
        "result": {
          "firstName": "John",
          "lastName": "DoeAlbany"
        }
      }

  # Verify update
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_person",
          "params": {
            "firstName": "John",
            "lastName": "DoeAlbany"
          }
        }
    response: |
      {
        "result": {
          "firstName": "John",
          "lastName": "DoeAlbany",
          "age": 21,
          "address": {
            "street": "1 Main St",
            "city": "Albany",
            "state": "NY",
            "zip": 10001
          }
        }
      }

  # Update non-existent composite PK - returns null
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_person",
          "params": {
            "firstName": "NonExistent",
            "lastName": "Person",
            "data": {
              "age": 99
            }
          }
        }
    response: |
      {
        "result": null
      }
