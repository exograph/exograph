# Test creating entity with composite PK (user-specified) via RPC
stages:
  # Create a person with composite PK
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_person",
          "params": {
            "data": {
              "firstName": "New",
              "lastName": "Person",
              "age": 25
            }
          }
        }
    response: |
      {
        "result": {"firstName": "New", "lastName": "Person"}
      }

  # Verify via get
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_person",
          "params": {
            "firstName": "New",
            "lastName": "Person"
          }
        }
    response: |
      {
        "result": {
          "firstName": "New",
          "lastName": "Person",
          "age": 25,
          "address": null
        }
      }
