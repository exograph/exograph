# Test update address with nested delete of people via RPC
stages:
  # Update address and delete a person
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_address",
          "params": {
            "street": "2 Main St",
            "city": "Boston",
            "state": "MA",
            "zip": 22101,
            "data": {
              "info": "The best address in the world",
              "people": {
                "delete": [{"firstName": "John", "lastName": "DoeBoston"}]
              }
            }
          }
        }
    response: |
      {
        "result": {"street": "2 Main St", "city": "Boston", "state": "MA", "zip": 22101}
      }

  # Verify all people at that address: deleted one is gone, other remains
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_people",
          "params": {
            "where": {"address": {"street": {"eq": "2 Main St"}, "city": {"eq": "Boston"}}},
            "orderBy": [{"lastName": "ASC"}]
          }
        }
    response: |
      {
        "result": [
          {"firstName": "Jane", "lastName": "SmithBoston", "age": 35, "address": {"street": "2 Main St", "city": "Boston", "state": "MA", "zip": 22101}}
        ]
      }
