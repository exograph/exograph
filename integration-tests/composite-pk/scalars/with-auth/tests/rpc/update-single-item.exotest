# Test update with composite primary key + auth
stages:
  # Admin can update person with composite PK
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_person",
          "params": {
            "firstName": "John",
            "lastName": "DoeAlbany",
            "data": {
              "age": 21
            }
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "firstName": "John",
          "lastName": "DoeAlbany"
        }
      }

  # Verify update
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_person",
          "params": {
            "firstName": "John",
            "lastName": "DoeAlbany"
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "firstName": "John",
          "lastName": "DoeAlbany",
          "age": 21,
          "address": {
            "street": "1 Main St",
            "city": "Albany",
            "state": "NY",
            "zip": 10001
          }
        }
      }
