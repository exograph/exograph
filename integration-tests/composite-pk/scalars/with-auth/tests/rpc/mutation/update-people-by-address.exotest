# Test collection update with auth - non-admin only affects own data
stages:
  # Non-admin updates all MA people's age, but only their own record is affected
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_people",
          "params": {
            "where": {"address": {"state": {"eq": "MA"}}},
            "data": {"age": 20}
          }
        }
    auth: |
      {
        "firstName": "Jane",
        "lastName": "SmithBoston"
      }
    response: |
      {
        "result": [
          {"firstName": "Jane", "lastName": "SmithBoston"}
        ]
      }

  # Verify only SmithBoston was updated, others unchanged
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_people",
          "params": {
            "where": {"address": {"state": {"eq": "MA"}}},
            "orderBy": [{"address": {"city": "ASC"}}, {"lastName": "ASC"}]
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": [
          {"firstName": "John", "lastName": "DoeBoston", "age": 30, "address": {"street": "2 Main St", "city": "Boston", "state": "MA", "zip": 22101}},
          {"firstName": "Jane", "lastName": "SmithBoston", "age": 20, "address": {"street": "2 Main St", "city": "Boston", "state": "MA", "zip": 22101}},
          {"firstName": "John", "lastName": "DoePlymouth", "age": 50, "address": {"street": "4 Main St", "city": "Plymouth", "state": "MA", "zip": 23600}},
          {"firstName": "Jane", "lastName": "SmithPlymouth", "age": 55, "address": {"street": "4 Main St", "city": "Plymouth", "state": "MA", "zip": 23600}}
        ]
      }
