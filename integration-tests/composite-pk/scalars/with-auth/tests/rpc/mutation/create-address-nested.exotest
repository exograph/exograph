# Test create address with nested people - access control
stages:
  # Admin can create address with nested people
  - operation:
      type: rpc
      payload: |
        {
          "method": "create_address",
          "params": {
            "data": {
              "street": "123 Main St",
              "city": "San Francisco",
              "state": "CA",
              "zip": 94101,
              "people": [
                {"firstName": "Alice", "lastName": "WonderSF", "age": 28}
              ]
            }
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {"street": "123 Main St", "city": "San Francisco", "state": "CA", "zip": 94101}
      }

  # Verify the created person at that address
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_people",
          "params": {
            "where": {"address": {"city": {"eq": "San Francisco"}}}
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": [
          {"firstName": "Alice", "lastName": "WonderSF", "age": 28, "address": {"street": "123 Main St", "city": "San Francisco", "state": "CA", "zip": 94101}}
        ]
      }
