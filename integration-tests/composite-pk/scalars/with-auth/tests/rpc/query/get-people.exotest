# Test collection query (get_people) returns array
stages:
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_people",
          "params": {
            "where": {
              "firstName": {
                "eq": "John"
              }
            },
            "orderBy": [
              {
                "lastName": "ASC"
              }
            ],
            "limit": 2
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": [
          {
            "firstName": "John",
            "lastName": "DoeAlbany",
            "age": 20,
            "address": {
              "street": "1 Main St",
              "city": "Albany",
              "state": "NY",
              "zip": 10001
            }
          },
          {
            "firstName": "John",
            "lastName": "DoeBoston",
            "age": 30,
            "address": {
              "street": "2 Main St",
              "city": "Boston",
              "state": "MA",
              "zip": 22101
            }
          }
        ]
      }
