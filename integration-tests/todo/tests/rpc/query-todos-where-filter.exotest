# Test that where filter works with RPC
operation:
  type: rpc
  payload: |
    {
      "method": "get_todos",
      "params": {
        "where": {"completed": {"eq": false}}
      }
    }
  unorderedPaths:
    - result
auth: |
  {
    "sub": null,
    "role": "admin"
  }
response: |
  {
    "result": [
      {
        "id": $.u1TodoIds[0],
        "title": "U1-T1",
        "completed": false,
        "priority": "MEDIUM",
        "user": {
          "id": $.u1Id
        }
      },
      {
        "id": $.u1TodoIds[2],
        "title": "U1-T3",
        "completed": false,
        "priority": "HIGH",
        "user": {
          "id": $.u1Id
        }
      },
      {
        "id": $.u2TodoIds[0],
        "title": "U2-T1",
        "completed": false,
        "priority": "MEDIUM",
        "user": {
          "id": $.u2Id
        }
      },
      {
        "id": $.u2TodoIds[2],
        "title": "U2-T3",
        "completed": false,
        "priority": "LOW",
        "user": {
          "id": $.u2Id
        }
      }
    ]
  }
