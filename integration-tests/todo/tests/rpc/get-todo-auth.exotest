# Test that get_todo by PK enforces access control.
# Todo has @access(self.user.id == AuthContext.id || AuthContext.role == "admin"),
# so users can only see their own todos, while admins can see all.
stages:
  # Admin can get any todo by PK
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todo",
          "params": {
            "by": {"id": $.u1TodoIds[0]}
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "id": $.u1TodoIds[0],
          "title": "U1-T1",
          "completed": false,
          "priority": "MEDIUM",
          "user": {
            "id": $.u1Id
          }
        }
      }

  # User1 can get their own todo
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todo",
          "params": {
            "by": {"id": $.u1TodoIds[0]}
          }
        }
    auth: |
      {
        "sub": $.u1Id,
        "role": "user"
      }
    response: |
      {
        "result": {
          "id": $.u1TodoIds[0],
          "title": "U1-T1",
          "completed": false,
          "priority": "MEDIUM",
          "user": null
        }
      }

  # User2 cannot get user1's todo (returns null, not error)
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todo",
          "params": {
            "by": {"id": $.u1TodoIds[0]}
          }
        }
    auth: |
      {
        "sub": $.u2Id,
        "role": "user"
      }
    response: |
      {
        "result": null
      }
