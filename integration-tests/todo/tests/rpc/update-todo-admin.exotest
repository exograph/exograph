# Test admin can update any todo by PK with projections
stages:
  # Admin updates — default projection (pk)
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_todo",
          "params": {
            "id": $.u1TodoIds[0],
            "data": {"title": "U1-T1-updated"}
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {"id": $.u1TodoIds[0]}
      }

  # Admin updates — withUser projection
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_todo",
          "params": {
            "id": $.u1TodoIds[0],
            "data": {"title": "U1-T1-updated2"},
            "projection": "withUser"
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "id": $.u1TodoIds[0],
          "title": "U1-T1-updated2",
          "completed": false,
          "priority": "MEDIUM",
          "user": {
            "id": $.u1Id,
            "email": "one@example.com",
            "firstName": "F1",
            "lastName": "L1",
            "profileImageUrl": "https://example.com/1.jpg",
            "role": "user"
          }
        }
      }

  # Verify final state
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todo",
          "params": {"id": $.u1TodoIds[0]}
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "id": $.u1TodoIds[0],
          "title": "U1-T1-updated2",
          "completed": false,
          "priority": "MEDIUM",
          "user": {"id": $.u1Id}
        }
      }
