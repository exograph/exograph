# Test user can update own todo (row-level access control)
stages:
  # User1 updates their own todo - should succeed
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_todo",
          "params": {
            "id": $.u1TodoIds[1],
            "data": {"title": "U1-T2-updated"}
          }
        }
    auth: |
      {
        "sub": $.u1Id,
        "role": "user"
      }
    response: |
      {
        "result": {"id": $.u1TodoIds[1]}
      }

  # Verify user1's todo is updated
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todo",
          "params": {
            "id": $.u1TodoIds[1]
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "id": $.u1TodoIds[1],
          "title": "U1-T2-updated",
          "completed": true,
          "priority": "MEDIUM",
          "user": {
            "id": $.u1Id
          }
        }
      }

  # User1 tries to update user2's todo - returns null (row-level predicate filters it out)
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_todo",
          "params": {
            "id": $.u2TodoIds[0],
            "data": {"title": "U2-T1-hacked"}
          }
        }
    auth: |
      {
        "sub": $.u1Id,
        "role": "user"
      }
    response: |
      {
        "result": null
      }

  # Verify user2's todo is unchanged
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todo",
          "params": {
            "id": $.u2TodoIds[0]
          }
        }
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": {
          "id": $.u2TodoIds[0],
          "title": "U2-T1",
          "completed": false,
          "priority": "MEDIUM",
          "user": {
            "id": $.u2Id
          }
        }
      }
