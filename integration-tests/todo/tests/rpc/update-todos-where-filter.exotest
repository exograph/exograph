# Test multi update with filter + access control
stages:
  # Admin updates all completed todos to mark them incomplete
  - operation:
      type: rpc
      payload: |
        {
          "method": "update_todos",
          "params": {
            "where": {"completed": {"eq": true}},
            "data": {"completed": false}
          }
        }
      unorderedPaths:
        - result
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": [{"id": $.u1TodoIds[1]}, {"id": $.u2TodoIds[1]}]
      }

  # Verify all todos are now incomplete
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todos",
          "params": {}
        }
      unorderedPaths:
        - result
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": [
          {"id": $.u1TodoIds[0], "title": "U1-T1", "completed": false, "priority": "MEDIUM", "user": {"id": $.u1Id}},
          {"id": $.u1TodoIds[1], "title": "U1-T2", "completed": false, "priority": "MEDIUM", "user": {"id": $.u1Id}},
          {"id": $.u1TodoIds[2], "title": "U1-T3", "completed": false, "priority": "HIGH", "user": {"id": $.u1Id}},
          {"id": $.u2TodoIds[0], "title": "U2-T1", "completed": false, "priority": "MEDIUM", "user": {"id": $.u2Id}},
          {"id": $.u2TodoIds[1], "title": "U2-T2", "completed": false, "priority": "MEDIUM", "user": {"id": $.u2Id}},
          {"id": $.u2TodoIds[2], "title": "U2-T3", "completed": false, "priority": "LOW", "user": {"id": $.u2Id}}
        ]
      }
