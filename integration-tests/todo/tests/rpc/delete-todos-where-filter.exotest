# Test multi delete with filter + access control
stages:
  # Admin deletes all completed todos
  - operation:
      type: rpc
      payload: |
        {
          "method": "delete_todos",
          "params": {
            "where": {"completed": {"eq": true}}
          }
        }
      unorderedPaths:
        - result
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": [{"id": $.u1TodoIds[1]}, {"id": $.u2TodoIds[1]}]
      }

  # Verify only incomplete todos remain
  - operation:
      type: rpc
      payload: |
        {
          "method": "get_todos",
          "params": {}
        }
      unorderedPaths:
        - result
    auth: |
      {
        "role": "admin"
      }
    response: |
      {
        "result": [
          {"id": $.u1TodoIds[0], "title": "U1-T1", "completed": false, "priority": "MEDIUM", "user": {"id": $.u1Id}},
          {"id": $.u1TodoIds[2], "title": "U1-T3", "completed": false, "priority": "HIGH", "user": {"id": $.u1Id}},
          {"id": $.u2TodoIds[0], "title": "U2-T1", "completed": false, "priority": "MEDIUM", "user": {"id": $.u2Id}},
          {"id": $.u2TodoIds[2], "title": "U2-T3", "completed": false, "priority": "LOW", "user": {"id": $.u2Id}}
        ]
      }
